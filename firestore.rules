rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // /config/site — the pamalaye | wedding stage the guest site reads
    // on every visit. Guests are unauthenticated, so read must be public.
    // Only signed-in admins can flip the stage.
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // /rsvps/{id} — anyone can submit a reply; only the admin dashboard
    // (signed in) can read the guest list or modify entries.
    match /rsvps/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
